{
  "name": "@kody-ade/engine",
  "version": "0.5.7",
  "description": "Kody ADE — the free, autonomous development engine. Issue to tested, reviewed PR.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kody-engine": "dist/bin/cli.js",
    "kody-lean": "dist/bin-v2/kody-lean.js"
  },
  "files": [
    "dist",
    "prompts",
    "templates",
    "kody.config.schema.json"
  ],
  "scripts": {
    "kody": "tsx src/entry.ts",
    "kody-lean": "tsx bin-v2/kody-lean.ts",
    "claude": "tsx scripts/kody.ts",
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=coverage/junit.xml",
    "test:lean": "vitest run --coverage src-v2",
    "test:lean:e2e": "vitest run e2e",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.92",
    "@types/proper-lockfile": "^4.1.4",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.7",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@vitest/coverage-v8": "^4.1.4",
    "playwright": "^1.59.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
