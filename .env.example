# ANTHROPIC_API_KEY=sk-ant-...

# GitHub (for PR creation, comments, labels)
# GH_TOKEN=ghp_...
# GH_PAT=ghp_...          # Preferred over GH_TOKEN

# Git identity (CI only)
# GIT_USER_EMAIL=bot@example.com
# GIT_USER_NAME=kody-bot

# LiteLLM proxy (optional — enables model routing, fallback, cost tracking)
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_MASTER_KEY=sk-litellm-key

# OpenAI (optional — for LiteLLM fallback models)
# OPENAI_API_KEY=sk-...

# Logging
# LOG_LEVEL=info
